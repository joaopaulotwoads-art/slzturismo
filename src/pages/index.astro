---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.tsx';
import TourCard from '../components/TourCard.astro';
import Footer from '../components/Footer.astro';
import { tours, whatsappNumber } from '../data/tours';
---

<Layout>
  <Header />

  <main>
    <!-- Hero Carousel (React - client:load) -->
    <HeroCarousel client:load />

    <!-- Tours Section -->
    <section id="passeios" class="relative py-20 sm:py-28 bg-surface">
      <!-- Decorative background -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl" />
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent/5 rounded-full blur-3xl" />
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16 sm:mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-5 py-2 mb-6">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-xs font-bold uppercase tracking-widest text-primary">Conheça nossos destinos</span>
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-dark">
            Nossos <span class="text-primary">Passeios</span>
          </h2>
          <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
            Experiências únicas em São Luís do Maranhão e Lençóis Maranhenses. Cada passeio é uma aventura inesquecível.
          </p>
        </div>

        <!-- Tour Cards -->
        <div class="space-y-16 sm:space-y-24">
          {tours.map((tour, index) => (
            <TourCard
              title={tour.title}
              highlights={tour.highlights}
              paragraphs={tour.paragraphs}
              image={tour.image}
              imageAlt={tour.imageAlt}
              whatsappMessage={tour.whatsappMessage}
              whatsappNumber={whatsappNumber}
              reverse={index % 2 !== 0}
              index={index}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Awards & Certificates Section -->
    <section id="avaliacoes" class="relative py-20 sm:py-28 bg-gradient-to-b from-accent-light/50 to-surface overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl" />
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-5 py-2 mb-6">
            <svg class="h-4 w-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span class="text-xs font-bold uppercase tracking-widest text-primary">Reconhecimento & Prêmios</span>
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-dark">
            Avaliações & <span class="text-primary">Certificados</span>
          </h2>
          <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
            Orgulhosamente premiados pelo TripAdvisor e reconhecidos como referência em turismo no Maranhão.
          </p>
        </div>

        <!-- Awards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
          <!-- TripAdvisor 2025 -->
          <div class="group flex flex-col items-center rounded-2xl bg-white p-6 shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <img
              src="/images/tripadvisor-2025.png"
              alt="Tripadvisor Travelers' Choice Awards 2025"
              class="w-full max-w-[200px] h-auto object-contain transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <p class="mt-4 text-sm font-bold text-text-dark text-center">Travelers' Choice Awards</p>
            <p class="text-xs text-text-muted">2025</p>
          </div>

          <!-- TripAdvisor 2024 -->
          <div class="group flex flex-col items-center rounded-2xl bg-white p-6 shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <img
              src="/images/tripadvisor-2024.png"
              alt="Tripadvisor Travellers' Choice Awards 2024"
              class="w-full max-w-[220px] h-auto object-contain transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <p class="mt-4 text-sm font-bold text-text-dark text-center">Travellers' Choice Awards</p>
            <p class="text-xs text-text-muted">Os melhores dos melhores</p>
          </div>

          <!-- TripAdvisor 2023 -->
          <div class="group flex flex-col items-center rounded-2xl bg-white p-6 shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <img
              src="/images/tripadvisor-2023.png"
              alt="Travelers' Choice 2023 TripAdvisor"
              class="w-full max-w-[220px] h-auto object-contain transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <p class="mt-4 text-sm font-bold text-text-dark text-center">Travelers' Choice</p>
            <p class="text-xs text-text-muted">TripAdvisor 2023</p>
          </div>

          <!-- Selo Top of Mind -->
          <div class="group flex flex-col items-center rounded-2xl bg-white p-6 shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <img
              src="/images/selo-top-of-mind.png"
              alt="Prêmio Top of Mind Brazil - Empresa Certificada 2021/22 - INBRAP"
              class="w-full max-w-[220px] h-auto object-contain transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <p class="mt-4 text-sm font-bold text-text-dark text-center">Top of Mind Brazil</p>
            <p class="text-xs text-text-muted">Empresa Certificada 2021/22</p>
          </div>

          <!-- Certificado INBRAP -->
          <div class="group flex flex-col items-center rounded-2xl bg-white p-6 shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
            <img
              src="/images/certificado-inbrap.jpg"
              alt="Certificado de Excelência INBRAP - SLZ Turismo Desde 2009 - Agência de Receptivo no Maranhão"
              class="w-full max-w-[220px] h-auto object-contain transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <p class="mt-4 text-sm font-bold text-text-dark text-center">Certificado de Excelência</p>
            <p class="text-xs text-text-muted">INBRAP — Agência de Receptivo</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-16 text-center">
          <a
            href="https://wa.me/5598983044843?text=Olá! Gostaria de reservar um passeio."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-full bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary-dark hover:-translate-y-1 hover:scale-105"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Reserve Agora
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- Floating WhatsApp Button -->
  <a
    href="https://wa.me/5598983044843?text=Olá! Gostaria de saber mais sobre os passeios."
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 flex h-16 w-16 items-center justify-center rounded-full bg-primary shadow-2xl shadow-primary/40 text-white transition-all hover:scale-110 hover:shadow-primary/60 animate-float"
    aria-label="Contato via WhatsApp"
  >
    <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
    </svg>
  </a>
</Layout>
