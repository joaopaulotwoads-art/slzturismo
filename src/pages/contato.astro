---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contato — SLZ Turismo | Fale Conosco" description="Entre em contato com a SLZ Turismo. Tire dúvidas, solicite orçamentos e reserve seus passeios nos Lençóis Maranhenses.">
  <Header />

  <main class="pt-28 pb-20 bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Page Title -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-5 py-2 mb-6">
          <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-widest text-primary">Contato</span>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-dark">
          Fale <span class="text-primary">Conosco</span>
        </h1>
        <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
          Pelo canal de atendimento aos clientes estamos disponíveis para atendê-los(a) da melhor forma
        </p>
      </div>

      <!-- Contact Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-text-dark mb-8">Informações de Contato</h2>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 flex-shrink-0">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-text-dark">(98) 98304-4843</p>
                <p class="text-sm text-text-muted">WhatsApp e Telefone</p>
              </div>
            </div>

            <!-- Email 1 -->
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 flex-shrink-0">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-text-dark">reservas@slzturismo.com.br</p>
                <p class="text-sm text-text-muted">Reservas</p>
              </div>
            </div>

            <!-- Email 2 -->
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 flex-shrink-0">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-text-dark">slz@slzturismo.com.br</p>
                <p class="text-sm text-text-muted">Geral</p>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 flex-shrink-0">
                <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-text-dark">Rio Poty Hotel</p>
                <p class="text-sm text-text-muted">Avenida dos Holandeses, Lote 2/5, Quadra 32, S/n – Ponta D'areia, São Luís – MA, 65071-380</p>
              </div>
            </div>

            <!-- Social -->
            <div class="flex items-center gap-4 pt-4">
              <a href="https://www.instagram.com/slz_turismo/" target="_blank" rel="noopener noreferrer" class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-purple-500 to-pink-500 text-white transition-transform hover:scale-110" aria-label="Instagram SLZ Turismo">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="https://wa.me/5598983044843?text=Olá,%20Gostaria%20de%20saber%20mais%20informações" target="_blank" rel="noopener noreferrer" class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white transition-transform hover:scale-110" aria-label="WhatsApp SLZ Turismo">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="rounded-2xl bg-white p-8 sm:p-10 shadow-xl">
          <h2 class="text-2xl font-bold text-text-dark mb-8">Envie uma mensagem</h2>
          <form action="https://formsubmit.co/reservas@slzturismo.com.br" method="POST" class="space-y-5">
            <input type="hidden" name="_subject" value="Nova mensagem do site SLZ Turismo">
            <input type="hidden" name="_next" value="https://slzturismo.com.br/contato">
            <input type="hidden" name="_captcha" value="false">

            <div>
              <label for="name" class="block text-sm font-medium text-text-dark mb-1">Nome</label>
              <input type="text" id="name" name="name" required placeholder="Seu nome" class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-text-dark placeholder-text-muted/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text-dark mb-1">E-mail</label>
              <input type="email" id="email" name="email" required placeholder="seu@email.com" class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-text-dark placeholder-text-muted/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-text-dark mb-1">Telefone</label>
              <input type="tel" id="phone" name="phone" placeholder="(00) 00000-0000" class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-text-dark placeholder-text-muted/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-text-dark mb-1">Mensagem</label>
              <textarea id="message" name="message" rows="4" required placeholder="Sua mensagem..." class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-text-dark placeholder-text-muted/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"></textarea>
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary-dark hover:-translate-y-0.5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Enviar
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
